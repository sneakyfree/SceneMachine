# SceneMachine Configuration
# Copy this file to .env and fill in your values

# Environment
NODE_ENV=development
SCENEMACHINE_ENV=development
SCENEMACHINE_DEBUG=1

# Database
DATABASE_URL=sqlite:///./data/scenemachine.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/scenemachine

# Storage paths (relative to project root or absolute)
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./data/outputs
MODEL_CACHE_DIR=./data/models

# =============================================================================
# API Keys (required for AI features)
# =============================================================================

# LLM Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Video Generation Providers
REPLICATE_API_TOKEN=           # Get from https://replicate.com/account/api-tokens
REPLICATE_VIDEO_MODEL=minimax  # Options: minimax, luma, kling, svd, runway-gen3

FAL_API_KEY=                   # Get from https://fal.ai/dashboard/keys
FAL_VIDEO_MODEL=ltx            # Options: ltx, cogvideox, hunyuan, mochi, fast-svd

RUNPOD_API_KEY=                # Get from https://www.runpod.io/console/user/settings
RUNPOD_ENDPOINT_ID=            # Your serverless endpoint ID

# Voice/TTS Providers
ELEVENLABS_API_KEY=            # Get from https://elevenlabs.io
ELEVENLABS_VOICE_ID=           # Default voice ID

# =============================================================================
# Generation Configuration
# =============================================================================

# LLM Configuration
DEFAULT_LLM_PROVIDER=anthropic

# Video Generation
DEFAULT_VIDEO_MODEL=local      # Options: local, replicate, fal, runpod, custom
MAX_CONCURRENT_GENERATIONS=2
GENERATION_TIMEOUT_SECONDS=600

# ComfyUI Local Generation (requires ComfyUI running locally)
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_DEFAULT_MODEL=animatediff-v3  # Options: animatediff-v3, animatediff-lightning, svd-xt, wan2-t2v

# =============================================================================
# Server Configuration
# =============================================================================

# Server (for development)
HOST=127.0.0.1
PORT=8000

# Security (change in production!)
SECRET_KEY=change-me-in-production-use-strong-random-key

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# IPC Configuration
IPC_SOCKET_PATH=/tmp/scenemachine.sock

# Logging
LOG_LEVEL=INFO
