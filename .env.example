# SceneMachine Configuration
# Copy this file to .env and fill in your values

# Environment
NODE_ENV=development
SCENEMACHINE_ENV=development
SCENEMACHINE_DEBUG=1

# Database
DATABASE_URL=sqlite:///./data/scenemachine.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/scenemachine

# Storage paths (relative to project root or absolute)
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./data/outputs
MODEL_CACHE_DIR=./data/models

# API Keys (required for AI features)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# LLM Configuration
DEFAULT_LLM_PROVIDER=anthropic

# Video Generation
DEFAULT_VIDEO_MODEL=local
MAX_CONCURRENT_GENERATIONS=2
GENERATION_TIMEOUT_SECONDS=600

# Server (for development)
HOST=127.0.0.1
PORT=8000

# Security (change in production!)
SECRET_KEY=change-me-in-production-use-strong-random-key

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
