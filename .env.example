# SceneMachine Configuration Template
# Copy this file to .env and fill in your values
#
# ⚠️  PRODUCTION: Replace SECRET_KEY and JWT_SECRET_KEY with cryptographically
#   random values. Generate with:
#     python -c "import secrets; print(secrets.token_urlsafe(32))"

# =============================================================================
# Environment
# =============================================================================
NODE_ENV=development
SCENEMACHINE_ENV=development
SCENEMACHINE_DEBUG=1

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=sqlite:///./data/scenemachine.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/scenemachine

# =============================================================================
# Storage Paths (relative to project root or absolute)
# =============================================================================
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./data/outputs
MODEL_CACHE_DIR=./data/models

# =============================================================================
# API Keys (required for AI features)
# =============================================================================

# LLM Providers (at least one required for screenplay parsing & copilot)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Video Generation Providers (at least one required for shot generation)
REPLICATE_API_TOKEN=           # https://replicate.com/account/api-tokens
REPLICATE_VIDEO_MODEL=minimax  # Options: minimax, luma, kling, svd, runway-gen3

FAL_API_KEY=                   # https://fal.ai/dashboard/keys
FAL_VIDEO_MODEL=ltx            # Options: ltx, cogvideox, hunyuan, mochi, fast-svd

RUNPOD_API_KEY=                # https://www.runpod.io/console/user/settings
RUNPOD_ENDPOINT_ID=            # Your serverless endpoint ID

# Voice/TTS Providers
ELEVENLABS_API_KEY=            # https://elevenlabs.io
ELEVENLABS_VOICE_ID=           # Default voice ID

# =============================================================================
# Generation Configuration
# =============================================================================
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_VIDEO_MODEL=local      # Options: local, replicate, fal, runpod, custom
MAX_CONCURRENT_GENERATIONS=2
GENERATION_TIMEOUT_SECONDS=600

# ComfyUI Local Generation (requires ComfyUI running locally)
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_DEFAULT_MODEL=animatediff-v3

# =============================================================================
# Server Configuration
# =============================================================================
HOST=127.0.0.1
PORT=8000

# Security (CHANGE THESE IN PRODUCTION!)
SECRET_KEY=CHANGE_ME_GENERATE_WITH_secrets_token_urlsafe_32
JWT_SECRET_KEY=CHANGE_ME_GENERATE_WITH_secrets_token_urlsafe_32

# CORS (JSON array format for pydantic-settings)
CORS_ORIGINS=["http://localhost:3000","http://localhost:51913"]

# IPC Configuration
IPC_SOCKET_PATH=/tmp/scenemachine.sock

# =============================================================================
# Redis (optional, for caching)
# =============================================================================
REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=
# REDIS_SSL=false
REDIS_MAX_CONNECTIONS=10
CACHE_DEFAULT_TTL_SECONDS=3600

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
