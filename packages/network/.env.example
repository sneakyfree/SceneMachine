# SceneMachine Network - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME="SceneMachine Network"
APP_VERSION="0.1.0"
DEBUG=true
ENVIRONMENT=development

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/scenemachine_network
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# For Docker Compose, use:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/scenemachine_network

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# For Docker Compose, use:
# REDIS_URL=redis://redis:6379/0

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# OAUTH2 PROVIDERS (Optional)
# =============================================================================
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# =============================================================================
# CLOUDFLARE R2 STORAGE
# =============================================================================
# Get these from Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=scenemachine-network
R2_PUBLIC_URL=

# For local development without R2, you can use MinIO:
# R2_ENDPOINT_URL=http://localhost:9000
# R2_ACCESS_KEY_ID=minioadmin
# R2_SECRET_ACCESS_KEY=minioadmin

# =============================================================================
# STRIPE PAYMENTS
# =============================================================================
# Get these from Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# =============================================================================
# EMAIL (SMTP)
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@scenemachine.network

# For local development, you can use Mailhog:
# SMTP_HOST=localhost
# SMTP_PORT=1025

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD_SECONDS=60

# =============================================================================
# CORS
# =============================================================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,https://scenemachine.network

# =============================================================================
# SERVICE URLS (Internal)
# =============================================================================
AUTH_SERVICE_URL=http://localhost:8001
CONTENT_SERVICE_URL=http://localhost:8002
STREAMING_SERVICE_URL=http://localhost:8003
SOCIAL_SERVICE_URL=http://localhost:8004
DISCOVERY_SERVICE_URL=http://localhost:8005
MONETIZATION_SERVICE_URL=http://localhost:8006
ANALYTICS_SERVICE_URL=http://localhost:8007
STUDIO_SERVICE_URL=http://localhost:8008
MODERATION_SERVICE_URL=http://localhost:8009

# For Docker Compose, use service names:
# AUTH_SERVICE_URL=http://auth-service:8001
# etc.

# =============================================================================
# STUDIO INTEGRATION
# =============================================================================
# URL to SceneMachine Studio desktop app API (for license verification)
STUDIO_API_URL=http://localhost:8000

# =============================================================================
# CELERY (Background Tasks)
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# =============================================================================
# CDN (Optional - for production)
# =============================================================================
CDN_URL=
CDN_PULL_ZONE=

# =============================================================================
# MONITORING (Optional)
# =============================================================================
SENTRY_DSN=
LOG_LEVEL=INFO
