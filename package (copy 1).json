{
  "name": "scenemachine",
  "version": "0.1.0",
  "private": true,
  "description": "Screenplay-to-Movie Generation Platform",
  "author": "SceneMachine Team",
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:desktop",
    "dev:desktop": "npm run dev -w apps/desktop",
    "build": "npm run build -w apps/desktop",
    "build:desktop": "npm run build -w apps/desktop",
    "package": "npm run package -w apps/desktop",
    "test": "npm run test --workspaces --if-present",
    "test:desktop": "npm run test -w apps/desktop",
    "lint": "npm run lint --workspaces --if-present",
    "lint:desktop": "npm run lint -w apps/desktop",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rm -rf node_modules",
    "prepare": "echo 'Ready to develop SceneMachine'"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
